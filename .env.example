# Configuração da aplicação (prefixo APP_). Copie para `.env` e ajuste conforme necessário.

APP_DATABASE_URL=sqlite:///./data/app.db
APP_UPLOAD_DIR=data/uploads
APP_MAX_UPLOAD_BYTES=209715200      # 200 MB
APP_MAX_DURATION_SECONDS=1800       # 30 minutos

# Ollama (Sprint 3) — ainda não consumido pelo backend
# APP_OLLAMA_URL=http://localhost:11434
